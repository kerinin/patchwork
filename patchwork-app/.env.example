# Supabase Configuration
# ---------------------
# This app supports both local (development) and remote (production) Supabase backends.
# Copy this file to .env and configure for your environment.

# Backend Mode: "local" or "remote"
# - local: Uses localhost Supabase (run `supabase start` in project root)
# - remote: Uses hosted Supabase project
PUBLIC_BACKEND_MODE=local

# ============================================================================
# LOCAL DEVELOPMENT (default)
# ============================================================================
# Run `supabase start` in the project root to get these values
# The values below are the defaults for local Supabase

PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Local Edge Functions URL (served by `supabase functions serve`)
PUBLIC_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

# ============================================================================
# REMOTE PRODUCTION
# ============================================================================
# Uncomment and configure these for production deployment
# Set PUBLIC_BACKEND_MODE=remote to use these values

# PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# PUBLIC_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# ============================================================================
# Dev-mode auto-login
# ============================================================================
# When enabled, the app will auto-login with these credentials in dev mode
# Create this user in Supabase Auth first: supabase dashboard -> Authentication -> Users

DEV_AUTO_LOGIN=true
DEV_USER_EMAIL=dev@patchwork.local
DEV_USER_PASSWORD=devpassword123
